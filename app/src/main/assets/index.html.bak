<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>YiControl – Surveillance</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.4.12/hls.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #090d0f;
    --bg2: #0e1518;
    --bg3: #131d21;
    --border: #1e3038;
    --green: #00e5a0;
    --green2: #00b87a;
    --red: #ff3b3b;
    --orange: #ff9500;
    --text: #cde8e0;
    --muted: #4a7a6a;
    --font-mono: 'Share Tech Mono', monospace;
    --font: 'Exo 2', sans-serif;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:var(--font); min-height:100vh; overflow-x:hidden; }

  /* Scanlines overlay */
  body::before {
    content:'';
    position:fixed; inset:0; pointer-events:none; z-index:999;
    background:repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
  }

  /* HEADER */
  header {
    display:flex; align-items:center; justify-content:space-between;
    padding:12px 16px; background:var(--bg2);
    border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100;
  }
  .logo { display:flex; align-items:center; gap:8px; }
  .logo-icon { width:32px; height:32px; background:var(--green); border-radius:6px;
    display:flex; align-items:center; justify-content:center; font-size:18px; }
  .logo-text { font-family:var(--font-mono); font-size:18px; color:var(--green); letter-spacing:2px; }
  .logo-sub { font-size:10px; color:var(--muted); letter-spacing:3px; margin-top:-2px; }
  .header-status { display:flex; align-items:center; gap:6px; font-family:var(--font-mono); font-size:11px; color:var(--muted); }
  .dot { width:7px; height:7px; border-radius:50%; background:var(--green); animation:pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  .time-display { font-family:var(--font-mono); font-size:13px; color:var(--green); }

  /* TABS */
  .tabs { display:flex; background:var(--bg2); border-bottom:1px solid var(--border); overflow-x:auto; }
  .tab {
    flex:1; min-width:70px; padding:12px 8px; text-align:center; cursor:pointer;
    font-size:11px; font-weight:600; letter-spacing:1px; text-transform:uppercase;
    color:var(--muted); border-bottom:2px solid transparent;
    transition:all .2s; white-space:nowrap;
  }
  .tab.active { color:var(--green); border-bottom-color:var(--green); background:rgba(0,229,160,0.05); }
  .tab-icon { font-size:16px; display:block; margin-bottom:2px; }

  /* PAGES */
  .page { display:none; padding:12px; animation:fadeIn .2s; }
  .page.active { display:block; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }

  /* CAMERA GRID */
  .cam-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:12px; }
  .cam-card {
    background:var(--bg2); border:1px solid var(--border); border-radius:10px;
    overflow:hidden; cursor:pointer; transition:border-color .2s;
    position:relative;
  }
  .cam-card:hover { border-color:var(--green2); }
  .cam-card.selected { border-color:var(--green); box-shadow:0 0 12px rgba(0,229,160,.2); }
  .cam-video-wrap { position:relative; width:100%; aspect-ratio:16/9; background:#000; }
  .cam-video-wrap video { width:100%; height:100%; object-fit:cover; display:block; }
  .cam-overlay {
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    background:rgba(0,0,0,.6); font-size:28px; flex-direction:column; gap:4px;
  }
  .cam-overlay span { font-size:10px; font-family:var(--font-mono); color:var(--muted); }
  .cam-badge {
    position:absolute; top:6px; left:6px; background:rgba(0,0,0,.7);
    border:1px solid var(--border); border-radius:4px;
    padding:2px 6px; font-family:var(--font-mono); font-size:9px; color:var(--green);
    display:flex; align-items:center; gap:4px;
  }
  .cam-badge.offline { color:var(--red); }
  .cam-badge.motion { color:var(--orange); animation:blink .5s infinite; }
  @keyframes blink { 50%{opacity:0} }
  .cam-name { padding:6px 8px; font-size:11px; font-weight:600; color:var(--text); display:flex; justify-content:space-between; align-items:center; }
  .cam-name small { font-family:var(--font-mono); font-size:9px; color:var(--muted); }

  /* LIVE PLAYER */
  .live-player {
    background:var(--bg2); border:1px solid var(--border); border-radius:12px;
    overflow:hidden; margin-bottom:12px;
  }
  .player-header { padding:10px 14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); }
  .player-title { font-family:var(--font-mono); font-size:13px; color:var(--green); }
  .player-video { width:100%; aspect-ratio:16/9; background:#000; position:relative; }
  .player-video video { width:100%; height:100%; object-fit:cover; }
  .no-stream {
    position:absolute; inset:0; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:8px; color:var(--muted);
  }
  .no-stream .icon { font-size:40px; opacity:.4; }
  .no-stream p { font-family:var(--font-mono); font-size:11px; text-align:center; line-height:1.6; }
  .player-controls { padding:10px 14px; display:flex; gap:8px; flex-wrap:wrap; }

  /* PTZ */
  .ptz-section { background:var(--bg2); border:1px solid var(--border); border-radius:12px; padding:14px; margin-bottom:12px; }
  .section-title { font-family:var(--font-mono); font-size:11px; color:var(--muted); letter-spacing:2px; text-transform:uppercase; margin-bottom:12px; }
  .ptz-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:6px; max-width:180px; margin:0 auto 12px; }
  .ptz-btn {
    aspect-ratio:1; background:var(--bg3); border:1px solid var(--border); border-radius:8px;
    display:flex; align-items:center; justify-content:center; font-size:18px; cursor:pointer;
    transition:all .15s; user-select:none; color:var(--text);
  }
  .ptz-btn:active { background:rgba(0,229,160,.15); border-color:var(--green); transform:scale(.93); }
  .ptz-center { background:rgba(0,229,160,.1); border-color:var(--green2); font-size:12px; font-weight:700; color:var(--green); }
  .zoom-controls { display:flex; gap:8px; justify-content:center; }

  /* BUTTONS */
  .btn {
    display:inline-flex; align-items:center; gap:6px; padding:8px 14px;
    border-radius:8px; border:1px solid var(--border); background:var(--bg3);
    color:var(--text); font-family:var(--font); font-size:12px; font-weight:600;
    cursor:pointer; transition:all .15s; white-space:nowrap;
  }
  .btn:active { transform:scale(.96); }
  .btn-green { background:var(--green); color:#000; border-color:var(--green); }
  .btn-red { background:var(--red); color:#fff; border-color:var(--red); }
  .btn-ghost { background:transparent; }
  .btn-sm { padding:5px 10px; font-size:11px; }

  /* ALERTS */
  .alerts-list { display:flex; flex-direction:column; gap:8px; }
  .alert-item {
    background:var(--bg2); border:1px solid var(--border); border-radius:10px;
    padding:12px; display:flex; align-items:center; gap:12px;
  }
  .alert-item.new { border-color:var(--orange); }
  .alert-thumb { width:56px; height:40px; background:var(--bg3); border-radius:6px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:20px; }
  .alert-info { flex:1; min-width:0; }
  .alert-title { font-size:13px; font-weight:600; margin-bottom:2px; }
  .alert-meta { font-family:var(--font-mono); font-size:10px; color:var(--muted); }
  .alert-badge { padding:3px 7px; border-radius:4px; font-size:10px; font-weight:700; background:rgba(255,149,0,.15); color:var(--orange); border:1px solid rgba(255,149,0,.3); }

  /* RECORDINGS */
  .rec-list { display:flex; flex-direction:column; gap:8px; }
  .rec-item {
    background:var(--bg2); border:1px solid var(--border); border-radius:10px;
    padding:12px; display:flex; align-items:center; gap:12px;
  }
  .rec-thumb { width:64px; height:44px; background:#000; border-radius:6px; flex-shrink:0; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:20px; }
  .rec-duration { position:absolute; bottom:2px; right:4px; font-family:var(--font-mono); font-size:8px; color:#fff; background:rgba(0,0,0,.7); padding:1px 3px; border-radius:2px; }
  .rec-info { flex:1; }
  .rec-name { font-size:13px; font-weight:600; margin-bottom:2px; }
  .rec-meta { font-family:var(--font-mono); font-size:10px; color:var(--muted); }
  .rec-size { font-family:var(--font-mono); font-size:10px; color:var(--green); margin-top:2px; }

  /* SETTINGS */
  .settings-group { background:var(--bg2); border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-bottom:12px; }
  .settings-group-title { padding:10px 14px; font-family:var(--font-mono); font-size:10px; color:var(--muted); letter-spacing:2px; text-transform:uppercase; border-bottom:1px solid var(--border); background:var(--bg3); }
  .setting-row { display:flex; align-items:center; justify-content:space-between; padding:12px 14px; border-bottom:1px solid var(--border); }
  .setting-row:last-child { border-bottom:none; }
  .setting-label { font-size:13px; font-weight:600; }
  .setting-sub { font-size:11px; color:var(--muted); margin-top:1px; }
  .setting-input { background:var(--bg3); border:1px solid var(--border); border-radius:6px; padding:6px 10px; color:var(--text); font-family:var(--font-mono); font-size:12px; width:140px; }
  .setting-input:focus { outline:none; border-color:var(--green); }
  .toggle { width:42px; height:24px; background:var(--bg3); border-radius:12px; position:relative; cursor:pointer; border:1px solid var(--border); transition:background .2s; }
  .toggle.on { background:var(--green); border-color:var(--green); }
  .toggle::after { content:''; position:absolute; top:3px; left:3px; width:16px; height:16px; border-radius:8px; background:#fff; transition:transform .2s; }
  .toggle.on::after { transform:translateX(18px); }

  /* Cam selector in settings */
  .cam-selector { display:flex; flex-direction:column; gap:8px; }
  .cam-config-row { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:12px; }
  .cam-config-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
  .cam-config-name { font-weight:600; font-size:13px; }
  .status-indicator { width:8px; height:8px; border-radius:50%; background:var(--muted); }
  .status-indicator.online { background:var(--green); }

  /* TOAST */
  .toast {
    position:fixed; bottom:80px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--bg3); border:1px solid var(--green); border-radius:8px;
    padding:10px 18px; font-family:var(--font-mono); font-size:12px; color:var(--green);
    opacity:0; pointer-events:none; transition:all .3s; z-index:200; white-space:nowrap;
  }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">📷</div>
    <div>
      <div class="logo-text">YiControl</div>
      <div class="logo-sub">SURVEILLANCE</div>
    </div>
  </div>
  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px">
    <div class="time-display" id="clock">--:--:--</div>
    <div class="header-status"><div class="dot"></div> SYSTÈME ACTIF</div>
  </div>
</header>

<div class="tabs">
  <div class="tab active" onclick="showPage('live')"><span class="tab-icon">📡</span>LIVE</div>
  <div class="tab" onclick="showPage('alerts')"><span class="tab-icon">🔴</span>ALERTES</div>
  <div class="tab" onclick="showPage('records')"><span class="tab-icon">🎞️</span>VIDÉOS</div>
  <div class="tab" onclick="showPage('settings')"><span class="tab-icon">⚙️</span>CONFIG</div>
</div>

<!-- ===== PAGE LIVE ===== -->
<div class="page active" id="page-live">

  <div class="cam-grid" id="camGrid">
    <!-- caméras générées en JS -->
  </div>

  <div class="live-player">
    <div class="player-header">
      <span class="player-title" id="playerTitle">▶ Sélectionne une caméra</span>
      <div class="header-status"><div class="dot" id="liveStatusDot" style="background:var(--muted)"></div> <span id="liveStatusText">HORS LIGNE</span></div>
    </div>
    <div class="player-video">
      <video id="mainVideo" autoplay muted playsinline controls></video>
      <div class="no-stream" id="noStream">
        <div class="icon">📷</div>
        <p>Sélectionne une caméra<br>pour voir le flux live</p>
      </div>
    </div>
    <div class="player-controls">
      <button class="btn btn-sm" onclick="toggleMute()">🔇 Muet</button>
      <button class="btn btn-sm" onclick="takeSnapshot()">📸 Capture</button>
      <button class="btn btn-sm btn-red" onclick="stopStream()">⏹ Stop</button>
    </div>
  </div>

  <div class="ptz-section">
    <div class="section-title">Contrôle PTZ — Rotation / Zoom</div>
    <div class="ptz-grid">
      <div class="ptz-btn" onclick="ptz('up-left')">↖</div>
      <div class="ptz-btn" onclick="ptz('up')">▲</div>
      <div class="ptz-btn" onclick="ptz('up-right')">↗</div>
      <div class="ptz-btn" onclick="ptz('left')">◀</div>
      <div class="ptz-btn ptz-center" onclick="ptz('home')">⌂</div>
      <div class="ptz-btn" onclick="ptz('right')">▶</div>
      <div class="ptz-btn" onclick="ptz('down-left')">↙</div>
      <div class="ptz-btn" onclick="ptz('down')">▼</div>
      <div class="ptz-btn" onclick="ptz('down-right')">↘</div>
    </div>
    <div class="zoom-controls">
      <button class="btn btn-sm" onclick="ptz('zoom-in')">🔍+ Zoom +</button>
      <button class="btn btn-sm" onclick="ptz('zoom-out')">🔍− Zoom −</button>
    </div>
  </div>
</div>

<!-- ===== PAGE ALERTES ===== -->
<div class="page" id="page-alerts">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <div style="font-size:14px;font-weight:700">Alertes mouvement</div>
    <button class="btn btn-sm" onclick="clearAlerts()">✓ Tout lire</button>
  </div>
  <div class="alerts-list" id="alertsList"></div>
</div>

<!-- ===== PAGE ENREGISTREMENTS ===== -->
<div class="page" id="page-records">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <div style="font-size:14px;font-weight:700">Enregistrements</div>
    <button class="btn btn-sm">📁 Filtre</button>
  </div>
  <div class="rec-list" id="recList"></div>
</div>

<!-- ===== PAGE PARAMÈTRES ===== -->
<div class="page" id="page-settings">

  <div class="settings-group">
    <div class="settings-group-title">Caméras — URLs RTSP</div>
    <div class="cam-selector" id="camSettings" style="padding:10px"></div>
  </div>

  <div class="settings-group">
    <div class="settings-group-title">Notifications</div>
    <div class="setting-row">
      <div>
        <div class="setting-label">Alertes mouvement</div>
        <div class="setting-sub">Notification en temps réel</div>
      </div>
      <div class="toggle on" id="toggle-motion" onclick="toggleSetting(this)"></div>
    </div>
    <div class="setting-row">
      <div>
        <div class="setting-label">Son d'alerte</div>
        <div class="setting-sub">Bip lors d'une détection</div>
      </div>
      <div class="toggle" id="toggle-sound" onclick="toggleSetting(this)"></div>
    </div>
  </div>

  <div class="settings-group">
    <div class="settings-group-title">Qualité vidéo</div>
    <div class="setting-row">
      <div>
        <div class="setting-label">Résolution</div>
        <div class="setting-sub">Flux principal</div>
      </div>
      <select class="setting-input" style="width:auto">
        <option>1080p HD</option>
        <option>720p</option>
        <option>480p</option>
      </select>
    </div>
  </div>

  <button class="btn btn-green" style="width:100%;justify-content:center;margin-bottom:60px" onclick="saveSettings()">💾 Sauvegarder</button>
</div>

<div class="toast" id="toast"></div>

<script>
// ====== STATE ======
const CAMERAS = [
  { id:1, name:"Entrée", loc:"Rez-de-chaussée", rtsp:"", status:"demo", hasMotion:false },
  { id:2, name:"Salon",  loc:"Intérieur",        rtsp:"", status:"demo", hasMotion:true },
  { id:3, name:"Jardin", loc:"Extérieur",         rtsp:"", status:"offline", hasMotion:false },
  { id:4, name:"Garage", loc:"Annexe",            rtsp:"", status:"offline", hasMotion:false },
];

// Flux de démo public (HLS) — sera remplacé par go2rtc + RTSP réel
const DEMO_STREAM = "https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8";

let selectedCam = null;
let hls = null;
let muted = true;

const ALERTS = [
  { id:1, cam:"Salon", time:"Aujourd'hui 14h32", type:"Mouvement", thumb:"🚶", isNew:true },
  { id:2, cam:"Entrée", time:"Aujourd'hui 12h10", type:"Mouvement", thumb:"🚗", isNew:true },
  { id:3, cam:"Jardin", time:"Hier 23h55", type:"Mouvement", thumb:"🌿", isNew:false },
  { id:4, cam:"Salon", time:"Hier 18h22", type:"Mouvement", thumb:"🐈", isNew:false },
];

const RECORDINGS = [
  { name:"Salon – Détection", date:"Aujourd'hui 14h32", duration:"0:42", size:"38 MB", thumb:"📹" },
  { name:"Entrée – Détection", date:"Aujourd'hui 12h10", duration:"1:12", size:"64 MB", thumb:"📹" },
  { name:"Enr. programmé", date:"Hier 20h00", duration:"60:00", size:"2.1 GB", thumb:"🎞️" },
  { name:"Salon – Détection", date:"Hier 18h22", duration:"0:28", size:"24 MB", thumb:"📹" },
];

// ====== INIT ======
function init() {
  renderCamGrid();
  renderAlerts();
  renderRecordings();
  renderCamSettings();
  startClock();
  simulateMotionAlerts();
}

// ====== CLOCK ======
function startClock() {
  const update = () => {
    const now = new Date();
    document.getElementById('clock').textContent = now.toLocaleTimeString('fr-FR');
  };
  update(); setInterval(update, 1000);
}

// ====== PAGES ======
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  event.currentTarget.classList.add('active');
}

// ====== CAM GRID ======
function renderCamGrid() {
  const grid = document.getElementById('camGrid');
  grid.innerHTML = CAMERAS.map(cam => {
    const isOnline = cam.status !== 'offline';
    const badgeClass = cam.hasMotion ? 'cam-badge motion' : (isOnline ? 'cam-badge' : 'cam-badge offline');
    const badgeText = cam.hasMotion ? '⚡ MOUVEMENT' : (isOnline ? '● LIVE' : '● HORS LIGNE');
    return `
    <div class="cam-card" id="camCard${cam.id}" onclick="selectCam(${cam.id})">
      <div class="cam-video-wrap">
        <video id="thumbVideo${cam.id}" muted playsinline style="width:100%;height:100%;object-fit:cover;display:${isOnline?'block':'none'}"></video>
        ${!isOnline ? `<div class="cam-overlay">📷<span>HORS LIGNE</span></div>` : ''}
        <div class="${badgeClass}">${badgeText}</div>
      </div>
      <div class="cam-name">${cam.name} <small>${cam.loc}</small></div>
    </div>`;
  }).join('');
}

function selectCam(id) {
  const cam = CAMERAS.find(c => c.id === id);
  if (!cam) return;
  if (cam.status === 'offline') { showToast('⚠ Caméra hors ligne'); return; }

  document.querySelectorAll('.cam-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('camCard' + id).classList.add('selected');
  selectedCam = cam;

  document.getElementById('playerTitle').textContent = '▶ ' + cam.name + ' — ' + cam.loc;
  document.getElementById('noStream').style.display = 'none';
  document.getElementById('liveStatusDot').style.background = 'var(--green)';
  document.getElementById('liveStatusText').textContent = 'EN DIRECT';

  playStream(cam.rtsp || DEMO_STREAM);
}

function playStream(url) {
  const video = document.getElementById('mainVideo');
  if (hls) { hls.destroy(); hls = null; }
  if (Hls.isSupported()) {
    hls = new Hls();
    hls.loadSource(url);
    hls.attachMedia(video);
    hls.on(Hls.Events.MANIFEST_PARSED, () => video.play());
  } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
    video.src = url;
    video.play();
  } else {
    showToast('⚠ Format vidéo non supporté');
  }
}

// ====== CONTROLS ======
function toggleMute() {
  const video = document.getElementById('mainVideo');
  muted = !muted;
  video.muted = muted;
  showToast(muted ? '🔇 Son coupé' : '🔊 Son activé');
}

function takeSnapshot() {
  showToast('📸 Capture sauvegardée');
}

function stopStream() {
  const video = document.getElementById('mainVideo');
  if (hls) { hls.destroy(); hls = null; }
  video.src = '';
  document.getElementById('noStream').style.display = 'flex';
  document.getElementById('liveStatusDot').style.background = 'var(--muted)';
  document.getElementById('liveStatusText').textContent = 'HORS LIGNE';
  document.getElementById('playerTitle').textContent = '▶ Sélectionne une caméra';
  document.querySelectorAll('.cam-card').forEach(c => c.classList.remove('selected'));
  selectedCam = null;
}

function ptz(dir) {
  if (!selectedCam) { showToast('⚠ Aucune caméra sélectionnée'); return; }
  const labels = { up:'Haut', down:'Bas', left:'Gauche', right:'Droite',
    'up-left':'Haut-Gauche', 'up-right':'Haut-Droite',
    'down-left':'Bas-Gauche', 'down-right':'Bas-Droite',
    home:'Position initiale', 'zoom-in':'Zoom +', 'zoom-out':'Zoom −' };
  showToast('🎯 PTZ → ' + (labels[dir] || dir));
  // ICI : envoyer la commande PTZ à l'API Yi / go2rtc
  // fetch(`/api/ptz?cam=${selectedCam.id}&dir=${dir}`)
}

// ====== ALERTS ======
function renderAlerts() {
  document.getElementById('alertsList').innerHTML = ALERTS.map(a => `
    <div class="alert-item ${a.isNew ? 'new' : ''}" id="alert${a.id}">
      <div class="alert-thumb">${a.thumb}</div>
      <div class="alert-info">
        <div class="alert-title">${a.cam}</div>
        <div class="alert-meta">${a.time}</div>
      </div>
      ${a.isNew ? '<div class="alert-badge">NOUVEAU</div>' : ''}
    </div>`).join('');
}

function clearAlerts() {
  ALERTS.forEach(a => a.isNew = false);
  renderAlerts();
  showToast('✓ Alertes marquées comme lues');
}

function simulateMotionAlerts() {
  // Simule une alerte toutes les 30s en démo
  setTimeout(() => {
    ALERTS.unshift({ id: Date.now(), cam: 'Entrée', time: 'À l\'instant', type:'Mouvement', thumb:'👤', isNew:true });
    renderAlerts();
    showToast('🔴 Mouvement détecté — Entrée');
    const cam = CAMERAS.find(c => c.id === 1);
    if (cam) { cam.hasMotion = true; renderCamGrid(); }
    setTimeout(() => { if (cam) { cam.hasMotion = false; renderCamGrid(); } }, 8000);
  }, 30000);
}

// ====== RECORDINGS ======
function renderRecordings() {
  document.getElementById('recList').innerHTML = RECORDINGS.map(r => `
    <div class="rec-item">
      <div class="rec-thumb">${r.thumb}<div class="rec-duration">${r.duration}</div></div>
      <div class="rec-info">
        <div class="rec-name">${r.name}</div>
        <div class="rec-meta">${r.date}</div>
        <div class="rec-size">${r.size}</div>
      </div>
      <button class="btn btn-sm" onclick="showToast('▶ Lecture...')">▶</button>
    </div>`).join('');
}

// ====== SETTINGS ======
function renderCamSettings() {
  document.getElementById('camSettings').innerHTML = CAMERAS.map(cam => `
    <div class="cam-config-row">
      <div class="cam-config-header">
        <div class="cam-config-name">📷 ${cam.name} — ${cam.loc}</div>
        <div class="status-indicator ${cam.status !== 'offline' ? 'online' : ''}"></div>
      </div>
      <input class="setting-input" style="width:100%" placeholder="rtsp://IP:554/..." 
        value="${cam.rtsp}" id="rtsp${cam.id}"
        oninput="CAMERAS[${cam.id-1}].rtsp = this.value">
    </div>`).join('');
}

function toggleSetting(el) { el.classList.toggle('on'); }

function saveSettings() {
  CAMERAS.forEach(cam => {
    const input = document.getElementById('rtsp' + cam.id);
    if (input) cam.rtsp = input.value;
  });
  showToast('💾 Configuration sauvegardée');
}

// ====== TOAST ======
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

init();
</script>
</body>
</html>
